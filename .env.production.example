# Backend environment variables for production
# Copy this to .env.production and fill in the values

# Database (Supabase)
DATABASE_URL=postgresql://USER:PASS@HOST:PORT/DB

# GoWA credentials (must match GoWA APP_BASIC_AUTH)
GOWA_BASIC_USER=admin
GOWA_BASIC_PASS=admin

# WhatsApp setup password (used by frontend to authenticate setup actions)
GOWA_SETUP_PASSWORD=changeme
